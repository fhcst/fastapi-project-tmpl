# FastAPI Application Settings
FASTAPI_APP_ENVIRONMENT=dev
SESSION_SECRET=your_super_secret_key_here

# MongoDB Settings (shared with docker-compose service configuration)
# The host should match the service name in docker-compose.yml
MONGO_DB=online_mall
MONGO_USER=mall_user
MONGO_PASSWORD=mall_user_password
MONGO_URL=mongodb://mall_user:mall_user_password@mongodb:27017/online_mall?authSource=admin

# Optional Add-ons (uncomment and set to enable)
# Redis: run with `docker compose --profile redis up`
# REDIS_URL=redis://localhost:6379/0

# MinIO: run with `docker compose --profile minio up`
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin

# LakeFS: run with `docker compose --profile lakefs up`
# LAKEFS_ENDPOINT=http://localhost:8001
# LAKEFS_ACCESS_KEY=
# LAKEFS_SECRET_KEY=
